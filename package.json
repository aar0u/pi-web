{
  "name": "pi-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --exec \"node --env-file-if-exists=.env src/server.mjs\"",
    "build": "node scripts/check-syntax.mjs && pnpm vendor:check && node scripts/check-markdown-safety.mjs",
    "start": "node --env-file-if-exists=.env src/server.mjs",
    "vendor:update": "node scripts/update-vendor.mjs",
    "vendor:check": "node scripts/check-vendor.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.75.5",
    "marked": "18.0.4",
    "prismjs": "1.30.0"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "nodemon": "3.1.14"
  }
}
