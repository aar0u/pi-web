# pi-hub server config
PORT=8787
HOST=127.0.0.1

# Set to 1 only when binding to a non-loopback HOST on a trusted LAN/proxy.
PI_HUB_ALLOW_REMOTE=0

# Optional: require UI/API auth. Open the UI once with #token=<same-value>.
PI_HUB_TOKEN=

# Optional Telegram bot integration.
TELEGRAM_BOT_TOKEN_BUZZ=
TELEGRAM_CHAT_ID_BUZZ=
PI_HUB_TELEGRAM_CWD=

# Optional scheduler tuning.
PI_HUB_SCHEDULER_INTERVAL_MS=30000
